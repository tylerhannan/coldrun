#!/bin/bash
# Stop coldrun serve.
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_DIR="${COLDRUN_DATA:-$DIR/.clickbench}"
PID_FILE="${COLDRUN_PID_FILE:-$DATA_DIR/serve.pid}"

if [ ! -f "$PID_FILE" ]; then
  exit 0
fi
pid=$(cat "$PID_FILE")
kill "$pid" 2>/dev/null || true
for _ in $(seq 1 30); do
  kill -0 "$pid" 2>/dev/null || break
  sleep 0.2
done
kill -9 "$pid" 2>/dev/null || true
rm -f "$PID_FILE"
