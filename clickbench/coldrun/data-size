#!/bin/bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_DIR="${COLDRUN_DATA:-$DIR/.clickbench}"
if du -sb "$DATA_DIR" >/dev/null 2>&1; then
  du -sb "$DATA_DIR" | awk '{print $1}'
else
  # macOS / BSD du: no -b; report bytes from 1 KiB blocks.
  du -sk "$DATA_DIR" | awk '{print $1 * 1024}'
fi
