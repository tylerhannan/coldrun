#!/bin/bash
# Build release coldrun binary. Run from repo root or set COLDRUN_ROOT.
set -euo pipefail

ROOT="${COLDRUN_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"
cd "$ROOT"

if ! command -v cargo >/dev/null 2>&1; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
fi

cargo build --release -p coldrun-cli -q
install -m 755 "$ROOT/target/release/coldrun" /usr/local/bin/coldrun 2>/dev/null || true
